{
  "name": "pdf_buddy",
  "version": "8.0.0-rc.0",
  "description": "Set of React components for PDF annotation",
  "author": "Artem Tyurin <artem.tyurin@gmail.com>",
  "license": "MIT",
  "keywords": [
    "pdf",
    "highlight",
    "annotator",
    "react-component"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/src/index.js",
  "style": "./dist/style.css",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build_server": "NODE_OPTIONS=--max-old-space-size=4096 tsc -b && vite build",
    "start": "npm run build && serve -s dist",
    "watch": "tsc --noEmit --watch --project tsconfig.json",
    "lint": "npx @biomejs/biome format --write ./src",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-oauth/google": "^0.12.2",
    "@tailwindcss/vite": "^4.1.10",
    "axios": "^1.10.0",
    "jwt-decode": "^4.0.0",
    "katex": "^0.16.22",
    "lucide-react": "^0.515.0",
    "patch-package": "^8.0.0",
    "pdfjs-dist": "4.4.168",
    "postinstall-postinstall": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-pdf-highlighter": "^8.0.0-rc.0",
    "react-rnd": "^10.4.11",
    "react-router-dom": "^7.16.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "serve": "^14.2.4",
    "ts-debounce": "^4.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.5",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.6.2",
    "vite": "^5.3.3",
    "vite-plugin-dts": "^4.1.1"
  },
  "homepage": "https://github.com/Spitfire1970/pdf_buddy#readme"
}
